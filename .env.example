# ─── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://agrograph:changeme@postgres:5432/agrograph

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── S3 / MinIO ───────────────────────────────────────────────────────────────
S3_BUCKET=agrograph-snapshots
S3_ACCESS_KEY=your_aws_access_key_here
S3_SECRET_KEY=your_aws_secret_key_here
S3_REGION=us-east-1
# Dejar vacío para usar AWS S3 real; completar para MinIO u otro compatible
S3_ENDPOINT_URL=

# ─── Scraping ─────────────────────────────────────────────────────────────────
# Lista de proxies separados por coma: http://user:pass@host:port,http://...
PROXY_LIST=
# Cada cuántas horas se ejecuta el ciclo de scraping completo
SCRAPE_INTERVAL_HOURS=6

# ─── Autenticación ────────────────────────────────────────────────────────────
# Claves fijas por cliente (generar con: python -c "import secrets; print(secrets.token_hex(32))")
API_KEY_FRONTEND=replace_with_secure_random_hex_64_chars
API_KEY_LLM=replace_with_another_secure_random_hex_64_chars
# Secreto para firmar JWT (mínimo 32 caracteres)
JWT_SECRET=replace_with_minimum_32_char_random_secret_string
JWT_ALGORITHM=HS256
# Duración del token en minutos
JWT_EXPIRATION_MINUTES=1440

# ─── Aplicación ───────────────────────────────────────────────────────────────
DEBUG=false
